# config/cluster.env
# Source at the top of every SBATCH job script body (after #SBATCH headers).
# Do NOT hardcode these values in individual scripts.
#
# Usage in job scripts:
#   source "${HOME}/PROJECTS/al_active_dev/config/cluster.env"
#   module purge
#   module load "${CONDA_MODULE}"
#   conda activate "${CONDA_ENV}"

# ── Conda environment ──────────────────────────────────────────────────────
# Build with: conda env create -f config/environment.yml
CONDA_MODULE="anaconda3/2024.6"
CONDA_ENV="al_active_dev"

# ── MPI modules ────────────────────────────────────────────────────────────
INTEL_MODULE="intel/2022.2.0"
INTEL_MPI_MODULE="intel-mpi/intel/2021.7.0"
OPENMPI_MODULE="openmpi/gcc/4.1.2"

# ── Project paths ──────────────────────────────────────────────────────────
HOME_AL="${HOME}/PROJECTS/MODEL_COMPARISON"
SCRATCH_AL="/scratch/gpfs/zl4808/PROJECTS/MODEL_COMPARISON"
AL_ACTIVE_DEV="${HOME}/PROJECTS/al_active_dev"

# ── External data and utility paths ───────────────────────────────────────
DB_ROOT="${HOME}/scripts/GENDATA"
DB_PATH="${DB_ROOT}/databases"
USEFUL_FUNS="${HOME}/useful_functions"
# CORE_LIB and MD_CALCS are no longer needed: core.py and md_calcs_par live
# under al_active_dev/external/ and import directly. See external/md_calcs/README.md
# for the rebuild recipe when Python versions change.

# ── SLURM mail ─────────────────────────────────────────────────────────────
SBATCH_MAIL_USER="zl4808@princeton.edu"
SBATCH_MAIL_TYPE="FAIL"

# ── Numba (set in job scripts that use beam search) ────────────────────────
# export NUMBA_THREADING_LAYER=omp
# export NUMBA_NUM_THREADS=<n>
