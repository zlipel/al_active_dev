# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Virtual envs ──────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Logs & SLURM outputs (machine-local) ──────────────────────────────────
*.out
*.err
simlogs/

# ── Large data / pickled state (machine-local) ────────────────────────────
*.pkl
*.npy
*.npz
*.h5
*.hdf5
*.csv
!tests/**/*.csv

# ── LAMMPS / simulation outputs ───────────────────────────────────────────
*.lammpstrj
*.dump
*.restart*
*.lmp
!tests/**/*.lmp

# ── Beam search / scratch outputs ─────────────────────────────────────────
scratch/
runs/

# ── Vendored md_calcs build outputs (rebuilt per environment) ─────────────
external/md_calcs/build/
external/md_calcs/*.so

# ── AL artifact root (HOME-side: .pt checkpoints, plots, logs) ────────────
runs/
acq_logs/
simlogs/

# ── Archive (historical / cleanup artifacts; not production) ──────────────
archive/
file_inventory.txt

# ── Markdown policy: only READMEs are tracked ─────────────────────────────
# Ignore every .md file...
*.md
# ...then unignore any README.md anywhere in the tree
!**/README.md
